# MongoDB connection string
# Local: mongodb://localhost:27017/rewardx
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/rewardx?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/rewardx

# Server port
PORT=5000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_environment_12345
JWT_EXPIRE=7d

# Environment
NODE_ENV=development

# Frontend URL (for CORS in production)
# FRONTEND_URL=http://localhost:3000
